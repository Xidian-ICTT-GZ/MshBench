#!/bin/bash
# Git prepare-commit-msg hook: auto-prepend version tag to commit messages
# Install: ln -sf ../../.githooks/prepare-commit-msg .git/hooks/prepare-commit-msg

set -e

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Only modify when there's no explicit message (-m) and no template/merge/fixup
# i.e., only when the editor is opened (COMMIT_SOURCE is empty or "message")
if [ "$COMMIT_SOURCE" = "message" ] || [ -z "$COMMIT_SOURCE" ]; then
    LATEST_TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo "v0.0.0")
    FIRST_LINE=$(head -1 "$COMMIT_MSG_FILE")
    # Only prepend if it doesn't already start with the tag
    if [[ "$FIRST_LINE" != \[$LATEST_TAG\]* ]]; then
        sed -i '' "1s/^/[$LATEST_TAG] /" "$COMMIT_MSG_FILE"
    fi
fi